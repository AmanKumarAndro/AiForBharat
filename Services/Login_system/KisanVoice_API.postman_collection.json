{
  "info": {
    "name": "KisanVoice Auth API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://m5w47virua.execute-api.ap-south-1.amazonaws.com/dev"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Send OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+919876543210\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/send-otp",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "send-otp"]
        }
      }
    },
    {
      "name": "2. Verify OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "    pm.collectionVariables.set('token', jsonData.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+919876543210\",\n  \"otp\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/verify-otp",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "verify-otp"]
        }
      }
    },
    {
      "name": "3. Onboard Farmer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ramesh Kumar\",\n  \"userType\": \"farmer\",\n  \"totalLandArea\": 5.5,\n  \"latitude\": 28.4595,\n  \"longitude\": 77.0266,\n  \"city\": \"Gurgaon\",\n  \"state\": \"Haryana\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/farmer/onboard",
          "host": ["{{baseUrl}}"],
          "path": ["farmer", "onboard"]
        }
      }
    },
    {
      "name": "4. Get Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/farmer/profile",
          "host": ["{{baseUrl}}"],
          "path": ["farmer", "profile"]
        }
      }
    }
  ]
}
